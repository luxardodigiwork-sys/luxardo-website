rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /customers/{userId} {
      allow read, write: if true;
    }
    match /orders/{orderId} {
      allow read, write: if true;
    }
    match /sessions/{sessionId} {
      allow read, write: if true;
    }
    match /products/{productId} {
      allow read: if true;
      allow write: if true;
    }
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
